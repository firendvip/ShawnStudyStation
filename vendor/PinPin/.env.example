# 复制为 .env 使用
DATABASE_URL="file:./prisma/prod.db"

# 服务端 PDF 用的中文字体(Linux 安装 fonts-noto-cjk 后的路径)
PDF_FONT_PATH="/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc"

# 短信服务商:留空=演示模式(验证码直接返回前端,仅用于测试);
# 接入真实短信后设为 real(并在 lib/auth/codeSender.ts 实现 SmsCodeSender)。
# AUTH_SMS_PROVIDER=real

# ---------------------------------------------------------------------------
# 容器化部署(Docker)使用的值 —— 由 deploy/docker-compose.yml 注入,无需手填:
#
#   DATABASE_URL=file:/data/pinpin.db   # SQLite 落在挂载卷 pinpin-data 上
#   BASE_PATH=/pinpin                   # 构建时烤入,使应用挂载在 /pinpin 子路径
#   NODE_ENV=production
#
# BASE_PATH 必须在 `next build` 之前设置(已在 Dockerfile 用 ARG/ENV 处理)。
# 本地开发不要设置 BASE_PATH,保持无子路径的默认行为。
# ---------------------------------------------------------------------------
