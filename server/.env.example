PORT=4000
NODE_ENV=development
# Comma-separated list of exact allowed origins, e.g. https://app.example.com,https://admin.example.com
# Unset: dev falls back to localhost (3000, 5173); production blocks all origins.
CORS_ORIGIN=
JWT_SECRET=please-change-this-to-a-long-random-string
# PostgreSQL connection string (required). Format: postgres://user:pass@host:port/dbname
DATABASE_URL=postgres://xss:CHANGE_ME@localhost:5432/xss
# Set to true for managed Postgres providers that require SSL.
PGSSL=false
SMS_DEV_MODE=true
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
