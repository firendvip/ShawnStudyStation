# ===========================================================================
# 小善学习站 — 部署环境变量示例
# 用法: cp .env.example .env  然后填写下列各项。compose 会自动读取 .env。
#
# 安全提示:JWT_SECRET 与 POSTGRES_PASSWORD 必须使用强随机值,
#           例如:openssl rand -hex 32
#           切勿把填好的 .env 提交到 git(已被 .gitignore 忽略)。
# ===========================================================================

# 你的已备案域名(不带协议、不带斜杠),例如 study.example.com
# 用于后端 CORS_ORIGIN=https://${DOMAIN};Nginx 的 server_name 需另在配置文件中手改。
DOMAIN=study.example.com

# ---- PostgreSQL ----------------------------------------------------------
POSTGRES_USER=xss
# 必填:强随机密码(openssl rand -hex 32)
POSTGRES_PASSWORD=
POSTGRES_DB=xss

# ---- 后端鉴权 -------------------------------------------------------------
# 必填:强随机 JWT 密钥(openssl rand -hex 32)
JWT_SECRET=

# 短信演示模式:生产务必为 false(走真实腾讯云短信)
SMS_DEV_MODE=false

# ---- 腾讯云短信(真实发送所需的 6 个值,来自控制台 / docs 指引) ----------
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
