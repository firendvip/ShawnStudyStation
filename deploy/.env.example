# ===========================================================================
# 小善学习站 — 部署环境变量示例
# 用法: cp .env.example .env  然后填写下列各项。compose 会自动读取 .env。
#
# 安全提示:JWT_SECRET 与 POSTGRES_PASSWORD 必须使用强随机值,
#           例如:openssl rand -hex 32
#           切勿把填好的 .env 提交到 git(已被 .gitignore 忽略)。
# ===========================================================================

# 你的已备案域名(不带协议、不带斜杠),例如 study.example.com
# 用于后端 CORS_ORIGIN=https://${DOMAIN};Nginx 的 server_name 需另在配置文件中手改。
DOMAIN=s.look3.cn

# ---- PostgreSQL ----------------------------------------------------------
POSTGRES_USER=xss
# 必填:强随机密码(openssl rand -hex 32)
POSTGRES_PASSWORD=
POSTGRES_DB=xss

# ---- 后端鉴权 -------------------------------------------------------------
# 必填:强随机 JWT 密钥(openssl rand -hex 32)
JWT_SECRET=

# 邮箱验证码演示模式:生产务必为 false(走真实 SMTP 发信)
EMAIL_DEV_MODE=false

# ---- 邮箱验证码 SMTP(真实发送所需,来自邮箱服务商 / docs 指引) ----------
# 见 ../docs/邮箱验证码配置指引.md;个人可用 QQ/163 邮箱授权码或 Gmail 应用专用密码。
# QQ 邮箱填法:SMTP_HOST=smtp.qq.com、SMTP_PORT=465、SMTP_SECURE=true、
#             SMTP_USER=你的QQ邮箱、SMTP_PASS=QQ邮箱授权码、SMTP_FROM=小善学习站 <你的QQ邮箱>
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
# 注意:此处填「授权码 / 应用专用密码」,不是邮箱登录密码
SMTP_PASS=
# 发件人,需与 SMTP_USER 同邮箱,格式如:小善学习站 <你的邮箱@qq.com>
SMTP_FROM=
